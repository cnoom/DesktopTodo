<UserControl x:Class="DesktopTodo.Views.InlineEditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DesktopTodo.Converters"
             MinWidth="280">
    <UserControl.Resources>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter" />
    </UserControl.Resources>
    <StackPanel>
        <!-- 标题编辑 -->
        <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                 MinWidth="200"
                 Height="24"
                 x:Name="TitleTextBox" />

        <!-- 颜色预览条 -->
        <Border Height="4"
                CornerRadius="2"
                Margin="0,4,0,0"
                HorizontalAlignment="Stretch"
                Background="{Binding ColorHex, Converter={StaticResource StringToBrushConverter}}" />

        <!-- RGB 滑动条 -->
        <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- R -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="R" VerticalAlignment="Center"
                       Foreground="Red" />
            <Slider Grid.Row="0" Grid.Column="1"
                    Minimum="0" Maximum="255"
                    Value="{Binding R, Mode=TwoWay}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Margin="4,2,0,2" />
            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="{Binding R}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />

            <!-- G -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="G" VerticalAlignment="Center"
                       Foreground="Green" />
            <Slider Grid.Row="1" Grid.Column="1"
                    Minimum="0" Maximum="255"
                    Value="{Binding G, Mode=TwoWay}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Margin="4,2,0,2" />
            <TextBlock Grid.Row="1" Grid.Column="2"
                       Text="{Binding G}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />

            <!-- B -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="B" VerticalAlignment="Center"
                       Foreground="DodgerBlue" />
            <Slider Grid.Row="2" Grid.Column="1"
                    Minimum="0" Maximum="255"
                    Value="{Binding B, Mode=TwoWay}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Margin="4,2,0,2" />
            <TextBlock Grid.Row="2" Grid.Column="2"
                       Text="{Binding B}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
        </Grid>

        <!-- 按钮行 -->
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <Button Content="清除颜色"
                    FontSize="10"
                    Padding="4,1,4,1"
                    Focusable="False"
                    Cursor="Hand"
                    Command="{Binding ClearColorCommand}" />
            <Button Content="保存"
                    FontSize="11"
                    Padding="12,3,12,3"
                    Margin="8,0,0,0"
                    Cursor="Hand"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
