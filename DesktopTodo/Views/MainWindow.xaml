<Window x:Class="DesktopTodo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DesktopTodo.ViewModels"
        xmlns:helpers="clr-namespace:DesktopTodo.Helpers"
        Title="DesktopTodo" Height="650" Width="600" MaxWidth="900"
        MinWidth="380" MinHeight="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

    <!-- 键盘快捷键（全局命令，TextBox 获得焦点时不会触发） -->
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTopLevelTaskCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveSettingsCommand}" />
    </Window.InputBindings>

    <!-- DataContext 由 App.xaml.cs 注入，此处不再定义 -->
    <!-- 转换器等资源已移至 App.xaml 的 MergedDictionaries -->

    <!-- 全局文字色随主题自动切换 -->
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="{Binding FontSize}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                    <Setter Property="Foreground" Value="Black" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid>
        <Border x:Name="MainContentBorder"
                Background="{Binding WindowBackground}"
                CornerRadius="{StaticResource CornerRadiusLarge}"
                BorderBrush="{Binding DataContext.AdaptiveBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.35"
                                  BlurRadius="16" ShadowDepth="4"
                                  Direction="270" />
            </Border.Effect>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" MinWidth="80" MaxWidth="260" x:Name="SidebarColumn" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 侧边分类栏 -->
                <Border Grid.Column="0" Margin="0,0,0,0"
                        Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                        CornerRadius="{StaticResource CornerRadiusMedium}"
                        Padding="6" AllowDrop="True"
                        DragOver="SidebarBorder_DragOver"
                        Drop="SidebarBorder_Drop">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="分类" FontWeight="SemiBold" Margin="0,0,0,6" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="CategoryItem"
                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                Margin="0,0,0,2" Padding="4,3"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="CategoryItem_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <!-- 任务计数 Badge -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TaskCount, StringFormat='({0})'}"
                                                           VerticalAlignment="Center"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Margin="4,0,4,0"
                                                           Visibility="{Binding TaskCount, Converter={StaticResource PositiveIntToVisibilityConverter}}" />
                                                <Button Grid.Column="2" Content="✕"
                                                        Width="18" Height="18"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{StaticResource DangerBrush}"
                                                        FontSize="{StaticResource FontSizeSmall}"
                                                        Click="DeleteCategoryButton_Click"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding Id, Converter={StaticResource PositiveIntToVisibilityConverter}}" />
                                            </Grid>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource CategorySelectedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <TextBox x:Name="NewCategoryTextBox"
                                     Height="24"
                                     VerticalAlignment="Center"
                                     KeyDown="NewCategoryTextBox_KeyDown" />
                            <TextBlock x:Name="NewCategoryPlaceholder"
                                       Text="输入分类名，回车添加..."
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="{StaticResource FontSizeNormal}" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- 侧边栏拖动分隔条 -->
                <GridSplitter Grid.Column="1" Width="6"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent"
                              ShowsPreview="False" />

                <!-- 主任务区 -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏（拖拽 + 窗口控制按钮） -->
                    <Border Grid.Row="0" Height="36"
                            Background="{StaticResource OverlayStrongBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            MouseLeftButtonDown="Window_MouseLeftButtonDown"
                            ToolTip="按住拖动窗口">
                        <Grid>
                            <!-- 左侧：标题 -->
                            <TextBlock Text="DesktopTodo" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Opacity="0.6" />
                            <!-- 右侧：按钮组 -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0">
                                <Button Content="⚙" Width="24" Height="24"
                                        Click="SettingsButton_Click"
                                        FontSize="14" Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{Binding AdaptiveForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Cursor="Hand" Focusable="False"
                                        ToolTip="设置（Ctrl+,）" Margin="0,0,8,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" CornerRadius="4"
                                                    Width="24" Height="24">
                                                <TextBlock Text="⚙" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.6"
                                                           x:Name="Icon" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Icon" Property="Opacity" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Style="{StaticResource MinimizeButtonStyle}"
                                        Click="MinimizeClick"
                                        ToolTip="最小化" Margin="0,0,8,0" />
                                <Button Style="{StaticResource CloseButtonStyle}"
                                        Click="CloseClick"
                                        ToolTip="关闭" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 标签过滤栏 -->
                    <Border Grid.Row="1" Margin="0,6,0,0"
                            Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="4">
                        <WrapPanel>
                            <TextBlock Text="标签过滤：" VerticalAlignment="Center"
                                       Margin="4,0,6,0" />
                            <ItemsControl ItemsSource="{Binding AllTags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}"
                                                Margin="2" Padding="4,1"
                                                Command="{Binding DataContext.ToggleFilterByTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource RoundedButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource TagChipSelectedBackgroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="删除标签" Click="DeleteTag_Click" Tag="{Binding}" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </Border>

                    <!-- 任务树 -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TreeView x:Name="TaskTreeView"
                                  ItemsSource="{Binding RootTasks}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Margin="0,0,0,8"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  helpers:TreeViewDragBehavior.IsEnabled="True"
                                  SelectedItemChanged="TaskTreeView_SelectedItemChanged">

                            <TreeView.Resources>
                                <!-- 树节点按钮内联样式 -->
                                <Style x:Key="TaskActionButtonStyle" TargetType="Button">
                                    <Setter Property="Width" Value="26" />
                                    <Setter Property="Height" Value="26" />
                                    <Setter Property="Background"
                                            Value="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                        BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{StaticResource OverlayHoverBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.Resources>

                            <!-- 应用提取的 TreeViewItem 样式 -->
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource TaskTreeViewItemStyle}" />
                            </TreeView.ItemContainerStyle>

                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type vm:TaskItemViewModel}"
                                                          ItemsSource="{Binding Children}">
                                    <!-- 外层 Grid：主内容层 + 按钮浮动层 -->
                                    <Grid Margin="2,3">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Task.IsCompleted}" Value="True">
                                                        <Setter Property="Opacity" Value="0.45" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <!-- 主内容层（固定布局，不受按钮显隐影响） -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- 左侧颜色条 -->
                                            <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                    Margin="0,0,4,0"
                                                    Background="{Binding Task.Color, TargetNullValue=Transparent, Converter={StaticResource StringToBrushConverter}}"
                                                    Visibility="{Binding Task.Color, Converter={StaticResource NullToVisibilityConverter}}" />

                                            <!-- 完成勾选框 -->
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding Task.IsCompleted, Mode=TwoWay}"
                                                      Style="{StaticResource TaskCheckBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,4,0"
                                                      Focusable="False" />

                                            <!-- 任务标题 -->
                                            <TextBlock x:Name="TaskTitleText"
                                                       Grid.Column="2"
                                                       Text="{Binding Task.Title}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,4,0"
                                                       TextWrapping="Wrap"
                                                       ToolTip="{Binding Task.Title}"
                                                       Foreground="{Binding DataContext.TaskFontBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       TextDecorations="{Binding Task.IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}" />

                                            <!-- 标签徽章 -->
                                            <ItemsControl Grid.Column="3" ItemsSource="{Binding Tags}" Margin="4,0"
                                                          MaxWidth="200">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="{StaticResource TagCornerRadius}"
                                                                Background="{StaticResource TagBadgeBackgroundBrush}"
                                                                Padding="3,1" Margin="1">
                                                            <Border.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="从任务删除"
                                                                              Click="RemoveTagFromTask_Click"
                                                                              Tag="{Binding}" />
                                                                </ContextMenu>
                                                            </Border.ContextMenu>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="{StaticResource FontSizeSmall}"
                                                                       Foreground="{Binding DataContext.AdaptiveTagFontBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>

                                        <!-- 操作按钮浮动层：右对齐，不影响主内容布局 -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    x:Name="ActionButtonsPanel"
                                                    Visibility="Collapsed"
                                                    Background="{Binding WindowBackground, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <!-- 编辑按钮 -->
                                            <Button Content="✎"
                                                    Style="{StaticResource TaskActionButtonStyle}"
                                                    Margin="4,0,2,0"
                                                    Click="EditButton_Click"
                                                    ToolTip="编辑任务（F2）" />

                                            <!-- 删除按钮 -->
                                            <Button Content="✖"
                                                    Style="{StaticResource TaskActionButtonStyle}"
                                                    Margin="2,0,2,0"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Click="DeleteButton_Click"
                                                    ToolTip="删除任务（Del）" />

                                            <!-- 添加子任务按钮 -->
                                            <Button Content="⊕"
                                                    Style="{StaticResource TaskActionButtonStyle}"
                                                    Margin="2,0,2,0"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    ToolTip="添加子任务（Ctrl+Shift+N）"
                                                    Command="{Binding DataContext.AddSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- hover 和完成状态的触发器 -->
                                    <HierarchicalDataTemplate.Triggers>
                                        <!-- 鼠标悬停时显示操作按钮 -->
                                        <DataTrigger
                                            Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                            Value="True">
                                            <Setter TargetName="ActionButtonsPanel" Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </HierarchicalDataTemplate.Triggers>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <!-- 空状态引导 -->
                        <Border x:Name="EmptyStateBorder"
                                Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                CornerRadius="{StaticResource CornerRadiusMedium}"
                                Padding="20" Margin="0,40,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📋 还没有任务"
                                           FontSize="{StaticResource FontSizeLarge}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="输入任务标题后按 Enter 创建第一个任务"
                                           Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Ctrl+N 快速聚焦输入框 | Ctrl+Shift+N 添加子任务"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- 底部输入区 -->
                        <StackPanel Grid.Row="1" Margin="0,4,0,0">
                            <!-- 新建任务 -->
                            <Border
                                Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                Padding="8,6" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="新建任务" FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <Grid Grid.Row="1">
                                        <TextBox x:Name="NewTaskTextBox"
                                                 Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                                 KeyDown="NewTaskTextBox_KeyDown"
                                                 VerticalAlignment="Center" />
                                        <TextBlock x:Name="NewTaskPlaceholder"
                                                   Text="输入任务标题，回车添加..."
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 添加标签 -->
                            <Border
                                Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                Padding="8,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="添加标签" FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <Grid Grid.Row="1">
                                        <TextBox x:Name="NewTagTextBox"
                                                 Height="24"
                                                 VerticalAlignment="Center"
                                                 KeyDown="NewTagTextBox_KeyDown" />
                                        <TextBlock x:Name="NewTagPlaceholder"
                                                   Text="选中任务后输入标签名，回车添加..."
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- 迷你模式图标（可拖拽，点击恢复窗口） -->
        <Border x:Name="MiniModeIcon"
                Visibility="Collapsed"
                Width="48" Height="48"
                Background="{Binding WindowBackground}"
                CornerRadius="12"
                BorderBrush="{Binding DataContext.AdaptiveBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                BorderThickness="1"
                MouseLeftButtonDown="MiniModeIcon_MouseLeftButtonDown"
                MouseMove="MiniModeIcon_MouseMove"
                MouseLeftButtonUp="MiniModeIcon_MouseLeftButtonUp"
                Cursor="Hand"
                ToolTip="点击恢复窗口 | 拖拽移动位置"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="MiniIconScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <TextBlock Text="✔" FontSize="22"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{Binding DataContext.AdaptiveForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                       Opacity="0.7" />
        </Border>

        <!-- 外观设置弹窗 -->
        <Popup x:Name="SettingsPopup"
               PlacementTarget="{Binding ElementName=SettingsButtonBorder}"
               Placement="Left"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Slide"
               Width="300">
            <Border Background="{Binding WindowBackground}"
                    CornerRadius="{StaticResource CornerRadiusMedium}"
                    BorderBrush="{Binding DataContext.AdaptiveBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,8,0">
                <StackPanel>
                    <!-- 弹窗标题 -->
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="设置" FontWeight="Bold" />
                        <Button Content="✕" HorizontalAlignment="Right"
                                Width="22" Height="22" FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                Cursor="Hand" Click="CloseSettingsPopup" />
                    </Grid>

                    <Separator Margin="0,0,0,10"
                               Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}" />

                    <!-- 背景透明度 -->
                    <TextBlock Text="背景透明度" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Minimum="0.1" Maximum="1" Value="{Binding BackgroundOpacity}"
                                TickFrequency="0.05" IsSnapToTickEnabled="True" />
                        <TextBlock Grid.Column="1" Text="{Binding BackgroundOpacity, StringFormat={}{0:P0}}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="36" />
                    </Grid>

                    <!-- 背景颜色 -->
                    <TextBlock Text="背景颜色" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="快速选择"
                               Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="4,0,0,4" />
                    <WrapPanel Margin="0,0,0,10">
                        <Button Width="36" Height="36" Margin="2" ToolTip="浅灰"
                                Command="{Binding SetColorCommand}" CommandParameter="#CCF0F0F0"
                                Background="#CCF0F0F0"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="白色"
                                Command="{Binding SetColorCommand}" CommandParameter="#CCFFFFFF"
                                Background="#CCFFFFFF"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="深蓝"
                                Command="{Binding SetColorCommand}" CommandParameter="#CC1E3A8A"
                                Background="#CC1E3A8A"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="暗绿"
                                Command="{Binding SetColorCommand}" CommandParameter="#CC065F46"
                                Background="#CC065F46"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="暗红"
                                Command="{Binding SetColorCommand}" CommandParameter="#CC991B1B"
                                Background="#CC991B1B"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="深灰"
                                Command="{Binding SetColorCommand}" CommandParameter="#CC303030"
                                Background="#CC303030"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="暗紫"
                                Command="{Binding SetColorCommand}" CommandParameter="#CC4A148C"
                                Background="#CC4A148C"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                    </WrapPanel>

                    <!-- RGB 滑块 -->
                    <TextBlock Text="自定义颜色（RGB）"
                               FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center"
                                   Foreground="#FFE57373" />
                        <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="{Binding Red}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Red}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center"
                                   Foreground="#FF81C784" />
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="{Binding Green}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Green}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center"
                                   Foreground="#FF64B5F6" />
                        <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="{Binding Blue}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Blue}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Grid>


                    <Separator Margin="0,0,0,10"
                               Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}" />

                    <!-- 字号设置 -->
                    <TextBlock Text="字体大小" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Minimum="9" Maximum="24" Value="{Binding FontSize}"
                                TickFrequency="1" IsSnapToTickEnabled="True" />
                        <TextBlock Grid.Column="1" Text="{Binding FontSize, StringFormat={}{0:F0}}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="24" />
                    </Grid>

                    <Separator Margin="0,0,0,10"
                               Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}" />

                    <!-- 任务字体颜色 -->
                    <TextBlock Text="任务字体颜色" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="快速选择"
                               Foreground="{Binding DataContext.AdaptiveMutedForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="4,0,0,4" />
                    <WrapPanel Margin="0,0,0,10">
                        <Button Width="36" Height="36" Margin="2" ToolTip="白色"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#FFFFFF"
                                Background="#FFFFFF"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="黑色"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#000000"
                                Background="#000000"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="浅灰"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#CCCCCC"
                                Background="#CCCCCC"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="淡蓝"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#B0D4F1"
                                Background="#B0D4F1"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="淡绿"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#A8D8B9"
                                Background="#A8D8B9"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="暖黄"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#FFE082"
                                Background="#FFE082"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                        <Button Width="36" Height="36" Margin="2" ToolTip="粉红"
                                Command="{Binding SetTaskFontColorCommand}" CommandParameter="#F8BBD0"
                                Background="#F8BBD0"
                                Template="{StaticResource ColorSwatchButtonTemplate}" />
                    </WrapPanel>

                    <!-- 任务字体颜色 RGB 滑块 -->
                    <TextBlock Text="自定义颜色（RGB）"
                               FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center"
                                   Foreground="#FFE57373" />
                        <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="{Binding TaskFontRed}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding TaskFontRed}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center"
                                   Foreground="#FF81C784" />
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="{Binding TaskFontGreen}" TickFrequency="1" IsSnapToTickEnabled="True"
                                Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding TaskFontGreen}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center"
                                   Foreground="#FF64B5F6" />
                        <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="{Binding TaskFontBlue}" TickFrequency="1" IsSnapToTickEnabled="True"
                                Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding TaskFontBlue}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Grid>

                    <Separator Margin="0,0,0,10"
                               Background="{Binding DataContext.AdaptiveOverlayBrush, RelativeSource={RelativeSource AncestorType=Window}}" />

                    <!-- 开机自启 -->
                    <CheckBox IsChecked="{Binding IsAutoStartEnabled}"
                              Content="开机自启" Margin="0,0,0,12"
                              Foreground="{Binding DataContext.AdaptiveForeground, RelativeSource={RelativeSource AncestorType=Window}}" />

                    <!-- 保存 + 重置 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="保存设置" Click="SaveSettingsClick"
                                Style="{StaticResource RoundedButtonStyle}"
                                Padding="12,4" Margin="0,0,8,0" />
                        <Button Content="恢复默认" Click="ResetSettingsClick"
                                Style="{StaticResource RoundedButtonStyle}"
                                Foreground="{StaticResource DangerBrush}"
                                Padding="12,4" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>